HF_CACHE=/home/user/.cache/huggingface
LMSTUDIO_MODELS=/home/user/.lmstudio/models

# llama-server Modell — Container-Pfad, hot-swap mit: scripts/switch-model.sh <pfad>
LLAMA_MODEL=/models/lmstudio-community/Qwen3.5-35B-A3B-GGUF/Qwen3.5-35B-A3B-Q4_K_M.gguf
# Multimodaler Projektor (optional, leer = kein --mmproj). Wird von
# switch-model.sh automatisch im Modellverzeichnis gesucht.
LLAMA_MMPROJ=/models/lmstudio-community/Qwen3.5-35B-A3B-GGUF/mmproj-Qwen3.5-35B-A3B-BF16.gguf
LLAMA_CTX=131072
# Multi-Token-Prediction (MTP) Spekulationsdecoding aktivieren (true/false)
LLAMA_MTP=false
# Anzahl Server-Slots. n_ctx pro Slot = LLAMA_CTX / LLAMA_PARALLEL.
# 1 = voller LLAMA_CTX für eine Session (kein zusätzlicher VRAM-Bedarf)
LLAMA_PARALLEL=1
