+# --- Kompat-Shim (wakeword-studio): torchaudio>=2.9 delegiert load/info an
+# torchcodec, dessen FFmpeg-Libs auf diesem Host fehlen. Für WAV/FLAC reicht
+# soundfile vollständig aus, daher werden load/info hier ersetzt.
+import soundfile as _sf
+
+
+def _sf_load(path, *args, **kwargs):
+    data, sr = _sf.read(str(path), dtype="float32", always_2d=True)
+    return torch.from_numpy(data.T), sr
+
+
+class _SfInfo:
+    def __init__(self, path):
+        i = _sf.info(str(path))
+        self.sample_rate = i.samplerate
+        self.num_frames = i.frames
+        self.num_channels = i.channels
+        self.bits_per_sample = 16
+
+
+torchaudio.load = _sf_load
+torchaudio.info = _SfInfo
